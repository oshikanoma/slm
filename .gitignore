# Secrets — never commit
.env
.env.*
*_env
*.slm_teacher_env
*.key
secrets*

# Model artifacts (large; downloaded from Colab, regenerable)
outputs/
artifacts/
*.safetensors
*-lora/
*-lora*.zip
*.ckpt

# Prediction outputs (regenerated per run)
base_preds*.jsonl
tuned_preds*.jsonl
calib*.jsonl
# transient scoring output (keep committed: RESULTS.md, results.v*.colab.md, results.leaderboard.md)
# NOTE: macOS FS is case-insensitive, so be explicit — do NOT ignore RESULTS.md.
/results-[0-9]*.md
/results.judged.md

# Local junk / scratch data + backups
data/junk*.jsonl
data/train.junk*.jsonl
data/*.sample.jsonl
data/synth_chunks/
data/v1_backup/
data/v2_backup/
data/tt.excluded.json
data/wikinews.excluded.json

# Python
__pycache__/
*.pyc
.ipynb_checkpoints/
.venv/
venv/
preds/
